# Docker Compose 用环境变量（可复制为 deploy/.env 或在 compose 中 env_file 引用）
# 与 server/.env.example 变量名一致

YAPI_PORT=7102
YAPI_DEV_CLIENT_PORT=7101
YAPI_ADMIN_ACCOUNT=admin@admin.com
YAPI_TIMEOUT=120000
YAPI_MAIL_ENABLE=false

YAPI_DATABASE_URL=postgresql://yapi:yapi@postgres:5432/yapi

# Next 构建/运行时代理 API（容器内访问本机 server）
YAPI_API_URL=http://127.0.0.1:7102
