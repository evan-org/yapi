{
  "name": "yapi-vendor",
  "homepage": "/",
  "version": "1.11.0",
  "description": "YAPI",
  "type": "commonjs",
  "scripts": {
    "predev": "node scripts/generate-plugin-module.js",
    "prebuild": "node scripts/generate-plugin-module.js",
    "dev": "npm run dev-server & npm run dev-client",
    "dev-web": "npm run dev --prefix web -- -p 4000",
    "dev-client": "npm run dev-web",
    "dev-server": "cross-env NODE_ENV=development nodemon server/app.js dev -L",
    "build-web": "node scripts/build-next-client.js",
    "verify-build": "node scripts/verify-next-build.js",
    "build": "npm run build-web && npm run verify-build",
    "start": "npm run start:web & cross-env NODE_ENV=production node server/app.js",
    "start:api": "cross-env NODE_ENV=production node server/app.js",
    "start:web": "npm run start --prefix web -- -p 4000 -H 0.0.0.0",
    "install-server": "node server/install.js",
    "test": "ava",
    "test:server": "ava test/server/**/*.test.js",
    "npm-publish": "node ./npm-publish.js",
    "lint:web": "npm run lint --prefix web"
  },
  "scripts-info": {
    "start": "启动 API + Next.js 前端",
    "install-server": "初始化数据库数据，用于安装",
    "dev": "开发：Hono API + Next 前端",
    "dev-server": "仅 API 开发服务",
    "dev-client": "仅 Next 前端",
    "test": "执行测试"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:evan-org/yapi.git"
  },
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@hono/node-ws": "^1.3.1",
    "ajv": "^5.5.1",
    "ajv-i18n": "^2.2.0",
    "ajv-keywords": "^5.1.0",
    "axios": "0.18.1",
    "compare-versions": "^3.4.0",
    "cpu-load": "~1.0.0",
    "crypto-js": "^3.1.9-1",
    "easy-json-schema": "0.0.2-beta",
    "fs-extra": "^3.0.1",
    "generate-schema": "^2.6.0",
    "hono": "^4.12.22",
    "json-schema-editor-visual": "^1.0.23",
    "json-schema-faker": "0.5.0-rc16",
    "json-schema-ref-parser": "4.0.0",
    "js-base64": "^2.5.2",
    "json5": "0.5.1",
    "jsondiffpatch": "0.3.11",
    "jsonwebtoken": "7.4.1",
    "jsrsasign": "^8.0.12",
    "ldapjs": "~2.3.3",
    "markdown-it": "8.4.0",
    "markdown-it-anchor": "4.0.0",
    "markdown-it-table-of-contents": "0.3.2",
    "md5": "~2.3.0",
    "mockjs": "^1.1.0",
    "moment": "^2.19.3",
    "mongodb": "3.1.8",
    "mongoose": "5.7.5",
    "mongoose-auto-increment": "5.0.1",
    "node-schedule": "^1.3.2",
    "nodemailer": "4.0.1",
    "qs": "^6.7.0",
    "request": "2.81.0",
    "safeify": "^5.0.5",
    "sha.js": "2.4.9",
    "sha1": "1.1.1",
    "swagger-client": "~3.10.13",
    "underscore": "1.8.3",
    "url": "0.11.0",
    "yapi-plugin-qsso": "^1.1.0"
  },
  "devDependencies": {
    "@types/ldapjs": "^2.2.5",
    "@types/node": "^18.15.5",
    "ava": "^0.22.0",
    "conventional-changelog-cli": "^2.1.1",
    "cross-env": "^5.2.0",
    "eslint": "^7.20.0",
    "eslint-config-standard": "^16.0.2",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.0.0",
    "ghooks": "^2.0.0",
    "markdown-it-include": "^1.0.0",
    "nodemon": "^2.0.2",
    "prettier": "^1.18.2",
    "validate-commit-msg": "^2.14.0",
    "ydoc-plugin-img-view": "^1.0.1"
  },
  "engines": {
    "node": ">= 18.0.0",
    "npm": ">= 8.0.0"
  },
  "packageManager": "yarn@3.2.0"
}
