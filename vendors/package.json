{
  "name": "yapi-vendor",
  "homepage": "/",
  "version": "1.11.0",
  "description": "YAPI",
  "type": "commonjs",
  "scripts": {
    "predev": "node scripts/generate-plugin-module.js",
    "prebuild": "node scripts/generate-plugin-module.js",
    "dev:vite": "vite",
    "dev:legacy": "vite",
    "build:vite": "vite build",
    "dev:web": "npm run dev --prefix web -- -p 4000",
    "build:web": "npm run build --prefix web",
    "start:web": "npm run start --prefix web -- -p 4000",
    "start": "node server/app.js",
    "install-server": "node server/install.js",
    "dev": "npm run dev-server & npm run dev-client",
    "dev-client": "npm run dev --prefix web -- -p 4000",
    "dev-server": "cross-env NODE_ENV=development nodemon server/app.js dev -L",
    "build-client": "node scripts/build-next-client.js",
    "build-client:vite": "node scripts/build-client.js",
    "verify-build": "node scripts/verify-next-build.js",
    "verify-build:vite": "node scripts/verify-build.js",
    "build": "npm run build-client && npm run verify-build",
    "test": "ava",
    "test:server": "ava test/server/**/*.test.js",
    "npm-publish": "node ./npm-publish.js",
    "fix": "eslint --fix --ext .js,.jsx client/"
  },
  "scripts-info": {
    "start": "运行生产环境服务器",
    "install-server": "初始化数据库数据，用于安装",
    "dev": "运行开发服务器",
    "dev-server": "运行后端开发服务器",
    "dev-client": "运行前端开发服务器",
    "test": "执行测试"
