{
  "name": "yapi",
  "version": "1.11.0",
  "private": true,
  "description": "YApi  monorepo：server（API）+ client（Next.js）",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "node scripts/start.js",
    "dev-server": "pnpm --filter yapi-server dev",
    "dev-client": "pnpm --filter yapi-client dev",
    "build-client": "pnpm --filter yapi-client build",
    "verify-build": "node scripts/verify-next-build.js",
    "build": "pnpm run build-client && pnpm run verify-build",
    "start": "node scripts/start.js --prod",
    "start-server": "pnpm --filter yapi-server start",
    "start-client": "pnpm --filter yapi-client start",
    "build:server": "pnpm --filter yapi-server build",
    "typecheck": "pnpm run typecheck:server && pnpm run typecheck:client",
    "typecheck:server": "pnpm --filter yapi-server typecheck",
    "typecheck:client": "pnpm --filter yapi-client typecheck",
    "test:server": "pnpm --filter yapi-server test",
    "lint:client": "pnpm --filter yapi-client lint"
  },
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.21.0",
  "engines": {
    "node": ">= 18.0.0",
    "pnpm": ">= 9.0.0"
  }
}
