{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "rootDir": ".",
    "outDir": "dist",
    "strict": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "noEmitOnError": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "types": ["node"],
    "moduleDetection": "force",
    "baseUrl": ".",
    "paths": {
      "yapi.js": ["./yapi.ts"],
      "models/*": ["./models/*"],
      "controllers/*": ["./controllers/*"],
      "utils/*": ["./utils/*"],
      "common/*": ["./common/*"],
      "middleware/*": ["./middleware/*"],
      "adapter/*": ["./adapter/*"]
    }
  },
  "include": ["**/*.ts", "types/**/*.d.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "common/tui-editor/dist",
    ".eslintrc.js",
    ".prettierrc.js"
  ]
}
