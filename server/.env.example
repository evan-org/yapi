# YApi Server 环境变量模板
# 本地开发：复制为 server/.env.local（勿提交 Git），填入数据库密码等私密项
# Docker/K8s：使用 deploy/.env 或 Secret 注入环境变量

# --- 服务 ---
YAPI_PORT=7102
YAPI_DEV_CLIENT_PORT=7101
YAPI_ADMIN_ACCOUNT=admin@admin.com
YAPI_TIMEOUT=120000
# YAPI_WEBROOT=/absolute/path/to/server
# YAPI_CLIENT_PUBLIC=/absolute/path/to/client/public
# YAPI_CLOSE_REGISTER=false
# YAPI_PASS_SALT=
# YAPI_SCRIPT_ENABLE=false
# YAPI_VERSION_NOTIFY=false

# --- PostgreSQL（二选一）---
# 新库须先手动导入：schema.sql（表结构）+ seed.sql（默认管理员）
# psql "$YAPI_DATABASE_URL" -f server/db/schema.sql
# psql "$YAPI_DATABASE_URL" -f server/db/seed.sql
# 推荐：连接串
# YAPI_DATABASE_URL=postgresql://yapi:yapi@127.0.0.1:5432/yapi
YAPI_DB_HOST=127.0.0.1
YAPI_DB_PORT=5432
YAPI_DB_NAME=yapi
YAPI_DB_USER=yapi
YAPI_DB_PASS=yapi
# YAPI_DB_POOL_SIZE=20

# --- 邮件（可选）---
YAPI_MAIL_ENABLE=false
# YAPI_MAIL_HOST=smtp.example.com
# YAPI_MAIL_PORT=465
# YAPI_MAIL_FROM=noreply@example.com
# YAPI_MAIL_USER=
# YAPI_MAIL_PASS=

# --- LDAP 登录（可选，JSON 对象）---
# YAPI_LDAP_LOGIN={"enable":true,"server":"ldap://...","baseDn":"...","searchDn":"...","searchStandard":"...","emailKey":"mail","usernameKey":"cn"}

# --- 第三方集成（可选，JSON 数组）---
# YAPI_INTEGRATIONS=[{"name":"qsso","options":{"loginUrl":"...","emailPostfix":"@corp.com"}}]
