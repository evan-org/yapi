# YApi Server 环境变量（复制为 server/.env）
# 环境变量优先于 config.json

# 服务
YAPI_PORT=3001
YAPI_ADMIN_ACCOUNT=admin@admin.com
YAPI_TIMEOUT=120000
# YAPI_WEBROOT=/absolute/path/to/server
# YAPI_CLOSE_REGISTER=false
# YAPI_PASS_SALT=

# MongoDB（二选一）
# YAPI_MONGODB_URI=mongodb://127.0.0.1:27017/yapi
YAPI_DB_HOST=127.0.0.1
YAPI_DB_PORT=27017
YAPI_DB_NAME=yapi
# YAPI_DB_USER=
# YAPI_DB_PASS=
# YAPI_DB_AUTH_SOURCE=

# 邮件（可选）
YAPI_MAIL_ENABLE=false
# YAPI_MAIL_HOST=smtp.example.com
# YAPI_MAIL_PORT=465
# YAPI_MAIL_FROM=noreply@example.com
# YAPI_MAIL_USER=
# YAPI_MAIL_PASS=

# 插件列表 JSON（可选，与 config.json plugins 同结构）
# YAPI_PLUGINS=[]
