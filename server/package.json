{
  "name": "yapi-server",
  "version": "1.11.0",
  "description": "YApi Hono API 服务",
  "private": true,
  "type": "module",
  "main": "app.ts",
  "imports": {
    "#runtime": "./runtime.ts"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon",
    "start": "cross-env NODE_ENV=production tsx app.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "install-server": "tsx install.ts",
    "db:init": "tsx db/init-cli.ts",
    "pretest": "npm run build",
    "test": "cross-env YAPI_ENV=test NODE_OPTIONS=--experimental-vm-modules node ../node_modules/ava/cli.js dist/test/**/*.test.js",
    "npm-publish": "tsx npm-publish.ts"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@hono/node-ws": "^1.3.1",
    "ajv": "^5.5.1",
    "ajv-i18n": "^2.2.0",
    "ajv-keywords": "^5.1.0",
    "axios": "^1.8.4",
    "compare-versions": "^3.4.0",
    "cpu-load": "~1.0.0",
    "crypto-js": "^3.1.9-1",
    "dotenv": "^16.4.7",
    "easy-json-schema": "0.0.2-beta",
    "fs-extra": "^3.0.1",
    "generate-schema": "^2.6.0",
    "hono": "^4.12.22",
    "js-base64": "^2.5.2",
    "json-schema-editor-visual": "^1.0.23",
    "json-schema-faker": "0.5.0-rc16",
    "json-schema-ref-parser": "4.0.0",
    "json5": "0.5.1",
    "jsondiffpatch": "0.3.11",
    "jsonwebtoken": "^9.0.2",
    "jsrsasign": "^8.0.12",
    "ldapjs": "~2.3.3",
    "markdown-it": "8.4.0",
    "markdown-it-anchor": "4.0.0",
    "markdown-it-table-of-contents": "0.3.2",
    "md5": "~2.3.0",
    "mockjs": "^1.1.0",
    "moment": "^2.19.3",
    "pg": "^8.16.0",
    "node-schedule": "^1.3.2",
    "nodemailer": "4.0.1",
    "qs": "^6.7.0",
    "request": "2.81.0",
    "safeify": "^5.0.5",
    "sha.js": "2.4.9",
    "sha1": "1.1.1",
    "swagger-client": "~3.10.13",
    "underscore": "1.8.3",
    "url": "0.11.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/ldapjs": "^2.2.5",
    "@types/md5": "^2.3.5",
    "@types/node": "^18.15.5",
    "@types/pg": "^8.11.11",
    "@types/nodemailer": "^6.4.17",
    "@types/underscore": "^1.13.0",
    "ava": "^0.22.0",
    "cross-env": "^5.2.0",
    "nodemon": "^2.0.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 18.0.0",
    "npm": ">= 8.0.0"
  }
}
